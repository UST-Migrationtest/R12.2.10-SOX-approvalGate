# Git LFS tracking for Oracle EBS binary artifacts
*.fmb  filter=lfs diff=lfs merge=lfs -text
*.fmx  filter=lfs diff=lfs merge=lfs -text
*.pll  filter=lfs diff=lfs merge=lfs -text
*.rdf  filter=lfs diff=lfs merge=lfs -text
*.rep  filter=lfs diff=lfs merge=lfs -text
*.class filter=lfs diff=lfs merge=lfs -text
*.jar  filter=lfs diff=lfs merge=lfs -text

# Text file normalization
*.sql  text eol=lf
*.pks  text eol=lf
*.pkb  text eol=lf
*.prc  text eol=lf
*.fnc  text eol=lf
*.trg  text eol=lf
*.xml  text eol=lf
*.java text eol=lf
*.sh   text eol=lf
*.py   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.ldt  text eol=lf
*.wft  text eol=lf
